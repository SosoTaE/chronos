#!/bin/bash
#
# Git post-commit hook for Chronos time tracking integration
#
# This script automatically sends commit information to your local Chronos app
# when you make a commit. The commit details are appended to the currently
# active task or the most recent task.
#
# Installation:
#   1. Copy this file to your Git repository's hooks directory:
#      cp post-commit.sample /path/to/your/repo/.git/hooks/post-commit
#
#   2. Make it executable:
#      chmod +x /path/to/your/repo/.git/hooks/post-commit
#
#   3. Ensure Chronos app is running (webhook server on port 3030)
#
# Global Installation (for all new repos):
#   1. Copy to your Git template directory:
#      mkdir -p ~/.git-templates/hooks
#      cp post-commit.sample ~/.git-templates/hooks/post-commit
#      chmod +x ~/.git-templates/hooks/post-commit
#
#   2. Configure Git to use the template:
#      git config --global init.templatedir '~/.git-templates'
#
#   3. For existing repos, reinitialize:
#      cd /path/to/repo && git init
#

# Configuration
CHRONOS_WEBHOOK_URL="http://127.0.0.1:3030/api/webhooks/git"

# Get the commit information
COMMIT_MESSAGE=$(git log -1 --pretty=%B)
REPO_NAME=$(basename "$(git rev-parse --show-toplevel)")
AUTHOR=$(git log -1 --pretty=%an)
COMMIT_HASH=$(git rev-parse --short HEAD)

# Prepare JSON payload
JSON_PAYLOAD=$(cat <<EOF
{
  "commit_message": "$COMMIT_MESSAGE",
  "repo_name": "$REPO_NAME",
  "author": "$AUTHOR"
}
EOF
)

# Send the webhook request
# Using --silent to avoid cluttering git output
# Using --max-time 2 to avoid hanging if Chronos is not running
RESPONSE=$(curl --silent --max-time 2 \
  -X POST \
  -H "Content-Type: application/json" \
  -d "$JSON_PAYLOAD" \
  "$CHRONOS_WEBHOOK_URL" 2>/dev/null)

# Check if the request was successful
if [ $? -eq 0 ]; then
  echo "✓ Commit logged to Chronos: [$REPO_NAME] $COMMIT_HASH"
else
  # Silent failure - don't interrupt the git workflow
  # Uncomment the line below if you want to see errors:
  # echo "⚠ Chronos webhook unavailable (is the app running?)"
  :
fi

exit 0
